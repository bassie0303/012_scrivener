# Supabase 履歴同期（任意）。未設定でもアプリはローカル(IndexedDB)保存で動く。
# 値を入れて web/.env として保存する（.env は .gitignore 済み）。
#
# ★ 個人用プロジェクト（非公開）のキーを入れること。公開用プロジェクトのキーと混在させない。
# anon key で問題ない（RLS で auth.uid()=user_id に絞るため、サインインした本人しか読み書きできない）。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# サインインはアプリ画面のフォームから（メール＋パスワード）。
# 単一ユーザー前提。user_id は auth.uid() を使うので環境変数では持たない。
